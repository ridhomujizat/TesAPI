{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TesAPI",
  "version": "0.1.0",
  "identifier": "com.ridhomujizat.tesapi",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TesAPI",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/tesapi-mcp"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdFQjY1RUQ2RjkyQTgxRTkKUldUcGdTcjUxbDYyZnZuM2Y1RDhjbGdnT0ZxbGpFeG5MUHg3b1FHN0h4T0grNWtGeVhwdmxLc2EK",
      "endpoints": [
        "https://github.com/ridhomujizat/TesAPI/releases/latest/download/latest.json"
      ]
    }
  }
}
